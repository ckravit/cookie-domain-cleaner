{
  "manifest_version": 2,
  "name": "Cookie Domain Cleaner",
  "version": "2.1.0",
  "description": "Counts and deletes Firefox cookies whose cookie domain contains user-entered text. Defaults to microsoft.",
  "permissions": [
    "cookies",
    "<all_urls>"
  ],
  "browser_action": {
    "default_title": "Cookie Domain Cleaner",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "applications": {
    "gecko": {
      "id": "cookie-domain-cleaner-v2@example.local",
      "strict_min_version": "91.0"
    }
  },
  "icons": {
  "48": "cookie-eater.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@cookie-domain-cleaner",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
